{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cre-acquisition-orchestrator.local/schemas/phases/legal-data.schema.json",
  "title": "Legal Downstream Data",
  "type": "object",
  "required": [
    "agentFindings",
    "psaStatus",
    "titleStatus",
    "estoppelStatus",
    "insuranceStatus",
    "transferDocStatus",
    "closingChecklistStatus",
    "riskScore",
    "redFlagCount",
    "dataGapCount"
  ],
  "properties": {
    "agentFindings": {
      "type": "object",
      "patternProperties": {
        "^psa-reviewer$": {
          "$ref": "../agents/legal/psa-reviewer.schema.json"
        },
        "^loan-doc-reviewer$": {
          "$ref": "../common/agent-finding.schema.json"
        },
        "^title-survey-reviewer$": {
          "$ref": "../common/agent-finding.schema.json"
        },
        "^estoppel-tracker$": {
          "$ref": "../agents/legal/estoppel-tracker.schema.json"
        },
        "^insurance-coordinator$": {
          "$ref": "../agents/legal/insurance-coordinator.schema.json"
        },
        "^transfer-doc-preparer$": {
          "$ref": "../agents/legal/transfer-doc-preparer.schema.json"
        }
      },
      "additionalProperties": false
    },
    "psaStatus": {
      "type": "object",
      "required": [
        "reviewStatus"
      ],
      "properties": {
        "reviewStatus": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "titleStatus": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "estoppelStatus": {
      "type": "object",
      "required": [
        "returnRate"
      ],
      "properties": {
        "returnRate": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "insuranceStatus": {
      "type": "object",
      "required": [
        "overallStatus"
      ],
      "properties": {
        "overallStatus": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "loanDocStatus": {
      "type": "object",
      "required": [],
      "properties": {},
      "additionalProperties": false
    },
    "transferDocStatus": {
      "type": "object",
      "required": [
        "overallReadiness"
      ],
      "properties": {
        "overallReadiness": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "closingChecklistStatus": {
      "type": "object",
      "required": [],
      "properties": {
        "preClosingItems": {
          "type": "object",
          "required": [
            "completed",
            "total"
          ],
          "properties": {
            "completed": {
              "type": "number"
            },
            "total": {
              "type": "number"
            }
          },
          "additionalProperties": false
        },
        "closingDayItems": {
          "type": "object",
          "required": [
            "completed",
            "total"
          ],
          "properties": {
            "completed": {
              "type": "number"
            },
            "total": {
              "type": "number"
            }
          },
          "additionalProperties": false
        },
        "postClosingItems": {
          "type": "object",
          "required": [
            "identified",
            "total"
          ],
          "properties": {
            "identified": {
              "type": "number"
            },
            "total": {
              "type": "number"
            }
          },
          "additionalProperties": false
        },
        "criticalPathItems": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "riskScore": {
      "type": "number"
    },
    "redFlagCount": {
      "type": "number",
      "minimum": 0
    },
    "dataGapCount": {
      "type": "number",
      "minimum": 0
    },
    "redFlags": {
      "type": "array",
      "items": {
        "$ref": "../common/flag.schema.json"
      }
    },
    "dataGaps": {
      "type": "array",
      "items": {
        "$ref": "../common/flag.schema.json"
      }
    }
  },
  "additionalProperties": false
}
