{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cre-acquisition-orchestrator.local/schemas/codex/run-manifest.schema.json",
  "title": "Codex Live-Run Manifest",
  "type": "object",
  "definitions": {
    "repoRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "nullableRepoRelativePath": {
      "anyOf": [
        { "$ref": "#/definitions/repoRelativePath" },
        { "type": "null" }
      ]
    }
  },
  "required": [
    "runId",
    "status",
    "runOutcome",
    "workflowId",
    "selectedAgents",
    "results"
  ],
  "properties": {
    "runId": { "type": "string", "minLength": 1 },
    "startedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": ["string", "null"], "format": "date-time" },
    "status": { "type": "string", "enum": ["RUNNING", "COMPLETE", "FAILED", "DRY_RUN"] },
    "runOutcome": { "type": ["string", "null"], "enum": ["success", "partial", "failed", null] },
    "codexVersion": { "type": ["string", "null"] },
    "codexLoginStatus": { "type": ["string", "null"] },
    "workflowId": { "type": "string", "minLength": 1 },
    "workflowName": { "type": ["string", "null"] },
    "scenarioName": { "type": ["string", "null"] },
    "dealId": { "type": ["string", "null"] },
    "dealPath": { "$ref": "#/definitions/nullableRepoRelativePath" },
    "inputSnapshotPath": { "$ref": "#/definitions/nullableRepoRelativePath" },
    "inputSnapshotSummary": { "type": ["object", "string", "null"] },
    "concurrency": { "type": "integer", "minimum": 1 },
    "sandbox": { "type": "string", "minLength": 1 },
    "search": { "type": "boolean" },
    "dryRun": { "type": "boolean" },
    "maxRetries": { "type": "integer", "minimum": 0 },
    "retryBaseMs": { "type": "integer", "minimum": 0 },
    "agentTimeoutMs": { "type": "integer", "minimum": 1 },
    "rerunFailed": { "type": "boolean" },
    "failedAgents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agentName", "status", "attempts"],
        "properties": {
          "phase": { "type": "string", "minLength": 1 },
          "phaseLabel": { "type": "string" },
          "agentName": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "attempts": { "type": "integer", "minimum": 0 },
          "error": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "selectedAgents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agentName"],
        "properties": {
          "phase": { "type": "string", "minLength": 1 },
          "phaseLabel": { "type": "string" },
          "agentName": { "type": "string", "minLength": 1 },
          "promptFile": { "$ref": "#/definitions/repoRelativePath" }
        },
        "additionalProperties": false
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["status", "agentName", "attempts"],
        "properties": {
          "status": { "type": "string", "minLength": 1 },
          "phase": { "type": "string", "minLength": 1 },
          "phaseLabel": { "type": "string" },
          "agentName": { "type": "string", "minLength": 1 },
          "attempts": { "type": "integer", "minimum": 0 },
          "promptPath": { "$ref": "#/definitions/nullableRepoRelativePath" },
          "outputPath": { "$ref": "#/definitions/nullableRepoRelativePath" },
          "logPath": { "$ref": "#/definitions/nullableRepoRelativePath" },
          "exitCode": { "type": ["integer", "null"] },
          "timedOut": { "type": "boolean" },
          "error": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "logExcerpt": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "RUNNING" }
        }
      },
      "then": {
        "properties": {
          "completedAt": { "type": "null" },
          "runOutcome": { "type": "null" }
        }
      },
      "else": {
        "properties": {
          "completedAt": { "type": "string", "format": "date-time" },
          "runOutcome": { "type": "string", "enum": ["success", "partial", "failed"] },
          "results": { "type": "array", "minItems": 1 }
        }
      }
    }
  ],
  "additionalProperties": false
}
