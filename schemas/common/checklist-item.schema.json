{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cre-acquisition-orchestrator.local/schemas/common/checklist-item.schema.json",
  "title": "Checklist Item",
  "type": "object",
  "required": [
    "id",
    "description",
    "status",
    "blocker",
    "owner",
    "dueAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "$ref": "enums.schema.json#/$defs/checklistStatus"
    },
    "blocker": {
      "type": "boolean"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "dueAt": {
      "type": "string",
      "format": "date-time"
    },
    "evidencePath": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
