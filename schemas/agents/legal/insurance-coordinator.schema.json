{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cre-acquisition-orchestrator.local/schemas/agents/legal/insurance-coordinator.schema.json",
  "title": "Insurance Coordinator Output",
  "type": "object",
  "required": [
    "status",
    "finding"
  ],
  "properties": {
    "status": {
      "$ref": "../../common/enums.schema.json#/$defs/status"
    },
    "finding": {
      "type": "string",
      "minLength": 1
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "annual"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "annual": {
            "type": "number"
          }
        },
        "additionalProperties": false
      }
    },
    "totalAnnualPremium": {
      "type": "number"
    },
    "perUnit": {
      "type": "number"
    }
  },
  "additionalProperties": false
}
